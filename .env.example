# AWS credentials (local dev only — EC2 uses IAM role in production)
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
AWS_REGION=ap-southeast-1

# S3
AWS_S3_BUCKET=your-bucket-name

# Cognito (optional for local UI — leave blank to use dev auth)
COGNITO_USER_POOL_ID=
COGNITO_CLIENT_ID=
# NEXT_PUBLIC_USE_DEV_AUTH=true

# SES
SES_FROM_EMAIL=no-reply@yourdomain.com

# JWT (Cognito issues these)
JWT_ISSUER=https://cognito-idp.ap-southeast-1.amazonaws.com/ap-southeast-1_XXXXXXXXX
JWT_AUDIENCE=your_cognito_app_client_id

# Database (overridden in docker-compose for local dev)
DATABASE_URL=postgres://postgres:localpass@localhost:5433/expensedb